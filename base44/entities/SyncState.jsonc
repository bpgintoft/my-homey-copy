{
  "name": "SyncState",
  "type": "object",
  "properties": {
    "sync_token": {
      "type": "string",
      "description": "Google Calendar incremental sync token"
    },
    "calendar_id": {
      "type": "string",
      "description": "Which calendar this sync token belongs to"
    },
    "last_synced_at": {
      "type": "string",
      "description": "ISO timestamp of the last successful sync run"
    }
  },
  "required": []
}